{
  "hosting": {
    "public": "build/web",
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "redirects": [
      {
        "source": "**",
        "has": [
          {
            "type": "host",
            "value": "www.rahulkushwaha.com.np"
          }
        ],
        "destination": "https://rahulkushwaha.com.np",
        "type": 301
      }
    ]
  }
}
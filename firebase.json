{
  "hosting": {
    "public": "build/web",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],

    "redirects": [
      {
        "source": "/**",
        "has": [
          {
            "type": "host",
            "value": "www.rahulkushwaha.com.np"
          }
        ],
        "destination": "https://rahulkushwaha.com.np/:splat",
        "type": 301
      }
    ],

    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}